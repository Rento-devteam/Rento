BOT_TOKEN="123456:abc"
PORT="3010"
WEBHOOK_PATH="/telegram/webhook"

# Public base URL where Telegram can reach this bot (no trailing slash).
# Example: https://bot.example.com
PUBLIC_BOT_BASE_URL="https://bot.example.com"

# Backend base URL reachable from the bot container (internal docker DNS OK).
# Example: http://backend:3000
BACKEND_BASE_URL="http://localhost:3000"

# Must match backend BOT_SECRET (used as x-bot-secret header)
BOT_SECRET="change_me_in_production"

# If "true", bot will call Telegram setWebhook on startup.
SET_WEBHOOK_ON_STARTUP="false"

