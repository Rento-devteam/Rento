# Copy to `.env` and adjust. With `docker-compose.yml` in this folder, Postgres is on host port 5434.
DATABASE_URL="postgresql://postgres:root@localhost:5434/rento?schema=public"
# Prepare: docker compose up -d && npx prisma migrate deploy
JWT_ACCESS_SECRET="dev_access_secret"
JWT_REFRESH_SECRET="dev_refresh_secret"

# Public base URL of the frontend (used to build links in emails and Telegram login callback URL).
APP_BASE_URL="http://localhost:3000"

# Telegram deep link base shown to users (Bot username must match).
TELEGRAM_BOT_DEEPLINK_BASE="https://t.me/rento_bot?start="

# Shared secret for bot -> backend calls (x-bot-secret header).
BOT_SECRET="change_me_in_production"

# SMTP
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_REQUIRE_TLS="false"
SMTP_DEBUG="true"
SMTP_SERVICE=""
SMTP_USER="user@example.com"
SMTP_PASS="app_password"
SMTP_FROM="user@example.com"
EMAIL_TEST_TO="user@example.com"

# Elasticsearch (UC-09 search). With docker-compose in this folder, ES is on http://localhost:9200
ELASTICSEARCH_NODE="http://localhost:9200"
# Optional; default rento-listings
# ELASTICSEARCH_LISTINGS_INDEX="rento-listings"

