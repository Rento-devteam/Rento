# Скопируйте в `.env` в этом же каталоге (`packages/backend`).
# HTTPS Геокодер Яндекс.Карт: ключ из кабинета разработчика именно для Geocoder HTTP API,
# не путать с ключом JavaScript API (карта в браузере).
#
# Если переменная «есть», а сервер её не видит — перезапустите процесс бэкенда после правок .env
YANDEX_GEOCODER_API_KEY=
