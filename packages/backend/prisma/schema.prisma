generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  PENDING_EMAIL_CONFIRMATION
  PENDING_TELEGRAM_LINK
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum ListingStatus {
  DRAFT
  PENDING_MODERATION
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum RentalPeriod {
  HOUR
  DAY
  WEEK
  MONTH
}

enum PaymentMethodStatus {
  ATTACHED
  FAILED
  REVOKED
}

enum BookingStatus {
  PENDING
  PENDING_PAYMENT
  PAYMENT_FAILED
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  DISPUTED
}

enum BookingSettlementStatus {
  NONE
  PENDING
  SETTLED
  FAILED
}

enum IdentityVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

model User {
  id                String                   @id @default(uuid())
  email             String?                  @unique
  passwordHash      String?
  fullName          String?
  phone             String?
  avatarUrl         String?
  role              UserRole                 @default(USER)
  status            UserStatus               @default(PENDING_EMAIL_CONFIRMATION)
  emailConfirmedAt  DateTime?
  telegramId        String?                  @unique
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  emailTokens       EmailConfirmationToken[]
  telegramLinkCodes TelegramLinkCode[]
  telegramLoginExchanges TelegramLoginExchangeCode[]
  refreshTokens     RefreshToken[]
  listings          Listing[]
  bookingsAsRenter  Booking[]
  paymentMethods    UserPaymentMethod[]
  identityVerification IdentityVerification?
  trustScore        TrustScore?
}

model IdentityVerification {
  id        String                     @id @default(uuid())
  userId    String                     @unique
  user      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider  String                     @default("ESIA")
  status    IdentityVerificationStatus  @default(PENDING)

  verifiedAt DateTime?
  expiresAt  DateTime?
  lastError  String?

  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  @@index([status])
  @@index([provider])
}

model TrustScore {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  currentScore   Int
  totalDeals     Int
  successfulDeals Int
  lateReturns    Int
  disputes       Int
  calculatedAt   DateTime

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([currentScore])
  @@index([calculatedAt])
}

model EmailConfirmationToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model TelegramLinkCode {
  id        String    @id @default(uuid())
  code      String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model TelegramLoginAttempt {
  id          String   @id @default(uuid())
  state       String   @unique
  redirectUrl String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  exchanges   TelegramLoginExchangeCode[]

  @@index([expiresAt])
}

model TelegramLoginExchangeCode {
  id        String   @id @default(uuid())
  code      String   @unique
  attemptId String
  attempt   TelegramLoginAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([attemptId])
  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model Category {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  icon      String?
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  listings  Listing[]
}

model Listing {
  id                   String                       @id @default(uuid())
  ownerId              String
  owner                User                         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  categoryId           String
  category             Category                     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  title                String
  description          String
  rentalPrice          Float
  rentalPeriod         RentalPeriod
  depositAmount        Float
  status               ListingStatus                @default(DRAFT)
  latitude             Float?
  longitude            Float?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  photos               ListingPhoto[]
  manualCalendarBlocks ListingManualCalendarBlock[]
  bookings             Booking[]

  @@index([ownerId])
  @@index([categoryId])
  @@index([status])
}

model ListingPhoto {
  id           String   @id @default(uuid())
  listingId    String
  listing      Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url          String
  thumbnailUrl String?
  order        Int      @default(0)
  isPrimary    Boolean  @default(false)
  uploadedAt   DateTime @default(now())

  @@unique([listingId, order])
  @@index([listingId])
}

model ListingManualCalendarBlock {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  @@index([listingId])
}

model UserPaymentMethod {
  id        String              @id @default(uuid())
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String
  last4     String
  cardType  String
  isDefault Boolean             @default(false)
  status    PaymentMethodStatus @default(ATTACHED)
  addedAt   DateTime            @default(now())

  @@unique([userId, token])
  @@index([userId])
}

model Booking {
  id        String   @id @default(uuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  renterId  String
  renter    User     @relation(fields: [renterId], references: [id], onDelete: Cascade)
  // Day-level projection (kept for compatibility with day calendar views).
  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  // Datetime interval for hour-based rentals and precise overlaps.
  // Nullable temporarily to allow backfilling via migration; API will require it.
  startAt                  DateTime?
  endAt                    DateTime?
  rentAmount               Float
  depositAmount            Float
  totalAmount              Float
  amountHeld               Float?
  paymentHoldId            String?
  paymentGateway           String?
  paymentAuthorizationCode String?
  status                   BookingStatus @default(PENDING)

  returnRenterConfirmedAt      DateTime?
  returnLandlordConfirmedAt    DateTime?
  returnMutualConfirmedAt      DateTime?
  returnAutoConfirmedAt        DateTime?
  returnConfirmationDeadlineAt DateTime?

  completedAt DateTime?

  settlementStatus        BookingSettlementStatus @default(NONE)
  settlementError         String?
  settlementRetryCount    Int                     @default(0)
  settlementNextRetryAt   DateTime?
  settlementLastAttemptAt DateTime?
  settledAt               DateTime?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([listingId])
  @@index([renterId])
  @@index([status])
  @@index([startAt, endAt])
  @@index([returnConfirmationDeadlineAt])
  @@index([settlementStatus])
  @@index([settlementNextRetryAt])
}
