# Copy to .env and adjust. With docker-compose in this folder, Postgres is on host port 5434.
DATABASE_URL="postgresql://postgres:root@localhost:5434/rento?schema=public"
# Integration tests (npm run test:integration) use this DATABASE_URL against a real Postgres.
# Prepare: docker compose up -d && npx prisma migrate deploy
JWT_ACCESS_SECRET="dev_access_secret"
JWT_REFRESH_SECRET="dev_refresh_secret"
APP_BASE_URL="http://localhost:3000"
TELEGRAM_BOT_DEEPLINK_BASE="https://t.me/rento_bot?start="
BOT_SECRET="change_me_in_production"

# Telegram bot runtime (separate service)
BOT_TOKEN=""
TELEGRAM_BOT_WEBHOOK_PATH="/telegram/webhook"
# Public URL where Telegram can reach bot webhook (no trailing slash)
TELEGRAM_BOT_PUBLIC_BASE_URL="https://bot.example.com"
TELEGRAM_BOT_PORT="3010"
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_REQUIRE_TLS="false"
SMTP_DEBUG="true"
SMTP_SERVICE=""
SMTP_USER="fuchsjinx7@yandex.ru"
SMTP_PASS=""
SMTP_FROM="fuchsjinx7@yandex.ru"
EMAIL_TEST_TO="fuchsjinx7@yandex.ru"
# S3-compatible storage (AWS S3, Yandex Object Storage, MinIO, etc.)
# Yandex Object Storage: create a bucket + static access key in the console.
#   S3_ENDPOINT="https://storage.yandexcloud.net"
#   S3_REGION="ru-central1"
#   S3_FORCE_PATH_STYLE="true"
#   S3_PUBLIC_BASE_URL="https://storage.yandexcloud.net/<your-bucket-name>"
# Make objects readable in the browser: bucket ACL / policy for public read on prefix listings/
#   or use a CDN / website endpoint — the app stores the public URL returned after upload.
# S3_BUCKET="rento-escrow-files"
# S3_REGION="ru-central1"
# S3_ENDPOINT="https://storage.yandexcloud.net"
# S3_ACCESS_KEY_ID="<your_access_key_id>"
# S3_SECRET_ACCESS_KEY="<your_secret_access_key>"
# S3_PUBLIC_BASE_URL="https://storage.yandexcloud.net/rento-escrow-files"
# S3_FORCE_PATH_STYLE="true"
S3_ENDPOINT=https://storage.yandexcloud.net
S3_REGION=ru-central1
S3_BUCKET=rento-escrow-files
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Elasticsearch (UC-09 search). With docker-compose in this folder, ES is on http://localhost:9200
ELASTICSEARCH_NODE="http://localhost:9200"
# Optional; default rento-listings
# ELASTICSEARCH_LISTINGS_INDEX="rento-listings"